{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Workflow State",
  "description": "Schema for .paper-workflow/state.yaml",
  "type": "object",
  "required": ["schema_version", "project_id", "paper_type", "research_type", "discipline", "language", "current_stage", "stages"],
  "properties": {
    "schema_version": {
      "type": "integer",
      "description": "Schema version number"
    },
    "project_id": {
      "type": "string",
      "description": "Unique project slug identifier"
    },
    "paper_type": {
      "type": "string",
      "enum": ["course_paper", "thesis", "proposal", "literature_review", "lab_report", "data_report", "survey_report", "journal_article", "book_report", "project_proposal", "policy_report"]
    },
    "research_type": {
      "type": "string",
      "enum": ["theoretical", "review", "empirical", "experimental", "case", "survey"]
    },
    "discipline": {
      "type": "string",
      "enum": ["humanities", "social_science", "economics_management", "engineering", "medicine", "computer_science", "interdisciplinary"]
    },
    "language": {
      "type": "string",
      "enum": ["zh", "en", "bilingual"]
    },
    "target_journal": {
      "type": ["string", "null"]
    },
    "current_stage": {
      "type": "string",
      "description": "Current active stage identifier"
    },
    "stages": {
      "type": "object",
      "description": "Map of stage_id → stage state",
      "patternProperties": {
        "^[a-z_]+$": {
          "type": "object",
          "required": ["status", "depends_on"],
          "properties": {
            "status": {
              "type": "string",
              "enum": ["pending", "in_progress", "done", "skipped", "blocked"]
            },
            "depends_on": {
              "type": "array",
              "items": { "type": "string" }
            },
            "started_at": {
              "type": ["string", "null"],
              "format": "date-time"
            },
            "completed_at": {
              "type": ["string", "null"],
              "format": "date-time"
            },
            "qa_status": {
              "type": "string",
              "enum": ["pending", "passed", "failed", "overridden"]
            },
            "qa_report": {
              "type": ["string", "null"]
            },
            "artifacts": {
              "type": "array",
              "items": { "type": "string" }
            },
            "blockers": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    },
    "overrides": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["stage", "timestamp"],
        "properties": {
          "stage": { "type": "string" },
          "timestamp": { "type": "string", "format": "date-time" },
          "reason": { "type": "string" },
          "missing_deps": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
